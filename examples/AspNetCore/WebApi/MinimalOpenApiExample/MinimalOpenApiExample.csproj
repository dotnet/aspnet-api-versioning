<Project Sdk="Microsoft.NET.Sdk.Web">

 <PropertyGroup>
  <TargetFramework>net11.0</TargetFramework>
  <AssemblyTitle>Example API</AssemblyTitle>
  <GenerateDocumentationFile>true</GenerateDocumentationFile>
 </PropertyGroup>

 <ItemGroup>
  <PackageReference Include="Microsoft.Extensions.ApiDescription.Server">
   <PrivateAssets>all</PrivateAssets>
   <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
  </PackageReference>
  <PackageReference Include="Scalar.AspNetCore" />
  <PackageReference Include="Scalar.AspNetCore.Microsoft" />

  <!-- Scalar package above brings Microsoft.AspNetCore.OpenApi 10 whose source gen doesn't work with latest Microsoft.OpenApi -->
  <!-- The latest preview of Microsoft.AspNetCore.OpenApi has the fixed source gen. -->
  <PackageReference Include="Microsoft.AspNetCore.OpenApi" />

  <Reference Include="Microsoft.AspNetCore.OpenApi.dll" />
 </ItemGroup>

 <ItemGroup>
  <ProjectReference Include="..\..\..\..\src\AspNetCore\WebApi\src\Asp.Versioning.OpenApi\Asp.Versioning.OpenApi.csproj" />
 </ItemGroup>

</Project>